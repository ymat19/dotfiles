if command -v tmux >/dev/null; then
  if [ -n "$USE_TMUX" ] && [ -z "$TMUX" ]; then
    tmux attach-session -t main || tmux new-session -s main
  fi
fi

export PATH="${XDG_BIN_HOME:-$HOME/.local/bin}:$PATH"
bindkey -v
bindkey 'jj' vi-cmd-mode
bindkey -M viins '^a' beginning-of-line
bindkey -M viins '^e' end-of-line

autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^g' edit-command-line
bindkey -s '^y' 'try\n'

# 1コマンドで worktree 付き claude を新規 tmux セッションとして起動する。
# worktree の作成・配置は claude --worktree に委譲し、ここは tmux セッション生成のみ担う。
# 使い方: cwt [worktree名]  (省略時は claude 側でランダム名)
cwt() {
  local name="$1"
  local session="wt-${name:-$RANDOM}"
  tmux new-session -d -s "$session" -c "$PWD" "claude --worktree ${name:+$name}"
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

